          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "dbus_audit": {
      "description": "`[dbus.audit]` — D-Bus call audit verbosity.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "description": "Audit verbosity (default `summary`).",
