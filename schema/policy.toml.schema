        "allow": {
          "description": "Syscalls explicitly allowed.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "lifecycle": {
      "description": "`[lifecycle]` — TTL and TTL action.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ttl": {
          "description": "Time-to-live in human form (`8h`, `30m`).",
