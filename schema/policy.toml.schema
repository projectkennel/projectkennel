    },
    "audit_file": {
      "description": "`[audit.file]` — the rotating file sink.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dir": {
          "description": "Directory the JSONL log is written to.",
          "type": "string"
        },
        "rotate_at_bytes": {
          "description": "Rotate the log once it reaches this size (human form, `10M`).",
          "type": "string"
        },
        "compress_after_seconds": {
          "description": "Compress a rotated segment after this many seconds.",
          "type": "integer",
          "minimum": 0
        },
        "retain_count": {
          "description": "How many rotated segments to retain.",
          "type": "integer",
          "minimum": 0
        }
      }
