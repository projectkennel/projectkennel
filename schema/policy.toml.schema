          "enum": [
            "exit",
            "stop",
            "warn",
            "renew"
          ]
        }
      }
    },
    "tty": {
      "description": "`[tty]` — terminal hardening for an interactive (PTY) workload.",
      "type": "object",
      "additionalProperties": false,
