          "description": "The syslog facility.",
          "type": "string"
        }
      }
    },
    "audit_empty": {
      "description": "An empty audit sink table (journald, stdout: no fields).",
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "audit_class": {
      "description": "A per-class audit level override.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "description": "The class level.",
          "type": "string",
          "enum": [
            "off",
            "denies-only",
            "summary",
            "full"
          ]
        }
      }
    },
    "threats": {
      "description": "Threat-tag metadata attached to a grant.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exposed": {
          "description": "Threat IDs this entry weakens defence against.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mitigated": {
          "description": "Threat IDs this entry actively mitigates.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
