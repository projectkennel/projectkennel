#!/usr/bin/env bash
# Project Kennel pre-push hook (CODING-STANDARDS.md §15.2).
#
# Mirrors the CI gate (§14). Slower than pre-commit; runs once per push. If this
# passes, CI is expected to pass. bash for `set -o pipefail` (§15.4).
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

run() {
	echo "pre-push: $*" >&2
	"$@"
}

run cargo fmt --all -- --check
run cargo clippy --all-targets --all-features -- -D warnings
run cargo test --all-features
run cargo build --offline --frozen --locked

# Supply-chain verifiers (§14). These land with the first vendored dependency
# (the kennel-checksum-verify crate and its shell witness); until they exist,
# there is nothing to verify, so skip with a notice rather than failing.
if [ -x src/tools/verify-checksums ] || cargo metadata --no-deps --format-version 1 2>/dev/null | grep -q '"kennel-checksum-verify"'; then
	run cargo run -q -p kennel-checksum-verify
else
	echo "pre-push: skipping tools/verify-checksums (no vendored deps yet)" >&2
fi
if [ -x src/tools/verify-checksums.sh ]; then
	run src/tools/verify-checksums.sh
else
	echo "pre-push: skipping src/tools/verify-checksums.sh (not present yet)" >&2
fi

exit 0
